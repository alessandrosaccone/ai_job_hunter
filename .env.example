# Copia questo file in .env e inserisci i tuoi valori.
# Non committare mai il file .env su GitHub.

# API DeepSeek (matching AI, espansione keyword, pre-filtri)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# API SerpApi (ricerca startup e annunci via Google Jobs)
SERPAPI_API_KEY=

# Punteggio minimo (0-10) per promuovere un annuncio nei risultati
MATCH_SCORE_THRESHOLD=7
