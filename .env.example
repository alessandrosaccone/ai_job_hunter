# Copia questo file in .env e inserisci i tuoi valori.
# Non committare mai il file .env su GitHub.

# API DeepSeek (matching AI, espansione keyword, pre-filtri, fallback ricerca)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Ricerca annunci — ordine fallback (default: serpapi,serper,dataforseo,apify,scraperapi,duckduckgo,deepseek)
# SEARCH_PROVIDER_ORDER=serpapi,serper,dataforseo,apify,scraperapi,duckduckgo,deepseek

# Provider di ricerca (configura quelli che usi; il router salta quelli senza chiave)
SERPAPI_API_KEY=
SERPER_API_KEY=
DATAFORSEO_LOGIN=          # email account (da API Access — non è una API key singola)
DATAFORSEO_PASSWORD=        # password API generata da DataForSEO (≠ password dashboard)
APIFY_API_TOKEN=
# APIFY_GOOGLE_SEARCH_ACTOR=apify~google-search-scraper
SCRAPERAPI_API_KEY=

# Punteggio minimo (0-10) per promuovere un annuncio nei risultati
MATCH_SCORE_THRESHOLD=7
